[
  {
    "id": "deploy-staging",
    "execute-command": "/opt/pavillion/deploy.sh",
    "command-working-directory": "/opt/pavillion",
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "REPLACE_WITH_WEBHOOK_SECRET",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature-256"
        }
      }
    }
  }
]
