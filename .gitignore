node_modules
dist
build
.DS_Store
coverage
docs/.vitepress/dist
docs/.vitepress/cache
.claude/orchestrators/logs/
logs
.vscode
storage

# Agent OS and Claude Code configuration
.agent-os
.cursor/rules
.serena
agent-os
.beads/
.claude/worktrees/

# Test artifacts
.playwright-mcp
playwright-report
test-results
.tmp

# Docker secrets directory (contains sensitive data)
# Keep .gitkeep but ignore all secret files
secrets/*
!secrets/.gitkeep

# Federation SSL certificates (generated on-demand)
docker/federation/ssl/*.crt
docker/federation/ssl/*.key

# Local configuration (use local.yaml.example as template)
.env
config/local.yaml
AGENTS.md

# Per-instance deploy state managed by bin/deploy.sh
# Lists secrets ever provisioned on this instance. Not for version control.
.deploy-state

# Per-instance Caddy snippets dropped into the extras.d extension point.
# README.md is tracked; *.caddyfile snippets are operator-supplied per-instance.
caddy-extras.d/*.caddyfile

# Per-instance staging webhook listener artifacts (adnanh/webhook).
# hooks.json contains DEPLOY_WEBHOOK_SECRET; the tracked template lives
# next to it as docker/staging/hooks.json.example. deploy.log is rotating
# output from the deploy hook (written to /opt/pavillion/deploy.log).
docker/staging/hooks.json
/deploy.log
